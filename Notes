*** Script:     |         } else if (type == 'account') {
*** Script:     |             var clientNumber = new GlideRecord('customer_account');
*** Script:     |             clientNumber.addQuery('sys_id', user);
*** Script:     |             clientNumber._skip_before_query_filter = true;
*** Script:     |             clientNumber.query();
*** Script:     |             if (clientNumber.next()) {
*** Script:     |                 number = clientNumber.getValue('u_bp_id');
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         return number.toString();
