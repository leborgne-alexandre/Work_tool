*** Script:     | 		} else {
*** Script:     | 			gr.addQuery('cmn_location_type', 'region');
*** Script:     | 			gr.addQuery('parent', country);
*** Script:     | 		}
*** Script:     | 
*** Script:     | 		gr.setLimit(1);
*** Script:     | 		gr.query();
*** Script:     | 
*** Script:     | 		if (gr.next()) {
*** Script:     | 			result = gr.getUniqueValue();
*** Script:     | 		}
*** Script:     | 
