*** Script:     |     _getClientNumber: function(user, type) {
*** Script:     |         //Gets client number through sys id of the user depending on the consumer/contact/account
*** Script:     |         var number;
*** Script:     |         if (type == 'consumer') {
*** Script:     |             var clientNumber = new GlideRecord('csm_consumer');
*** Script:     |             clientNumber.addQuery('sys_id', user);
*** Script:     |             clientNumber._skip_before_query_filter = true;
*** Script:     |             //clientNumber.addEncodedQuery('u_consumer_typeLIKEZDCIND');
*** Script:     |             clientNumber.query();
*** Script:     |             if (clientNumber.next()) {
*** Script:     |                 number = clientNumber.getValue('u_bp_id');
*** Script:     |             }
*** Script:     |         } else if (type == 'contact') {
*** Script:     |             var clientNumber = new GlideRecord('customer_contact');
*** Script:     |             clientNumber.addQuery('sys_id', user);
*** Script:     |             clientNumber._skip_before_query_filter = true;
*** Script:     |             clientNumber.query();
*** Script:     |             if (clientNumber.next()) {
*** Script:     |                 number = clientNumber.getValue('u_bp_id');
*** Script:     |             }
*** Script:     |         } else if (type == 'account') {
*** Script:     |             var clientNumber = new GlideRecord('customer_account');
*** Script:     |             clientNumber.addQuery('sys_id', user);
*** Script:     |             clientNumber._skip_before_query_filter = true;
*** Script:     |             clientNumber.query();
*** Script:     |             if (clientNumber.next()) {
*** Script:     |                 number = clientNumber.getValue('u_bp_id');
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         return number.toString();
*** Script:     |     },
