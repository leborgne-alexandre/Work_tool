*** Script:     |     /**
*** Script:     |     	@name removeDuplicates
*** Script:     |     	@author Nuno Martins.
*** Script:     |     	@params arr (array) 
*** Script:     |     	@description: Removes duplicates from any array
*** Script:     |     	@date: 03/04/2025
*** Script:     |     	**/
*** Script:     |     removeDuplicates: function(arr) {
*** Script:     | 
*** Script:     |         var uniqueArray = [];
*** Script:     |         for (var i = 0; i < arr.length; i++) {
*** Script:     |             //check to see if value array already; if not, add it
*** Script:     |             if (uniqueArray.indexOf(arr[i]) === -1) {
*** Script:     |                 uniqueArray.push(arr[i]);
*** Script:     |             }
*** Script:     |         }
*** Script:     |         return uniqueArray;
*** Script:     |     },
