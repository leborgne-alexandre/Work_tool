*** Script:     |     validateDates: function() {
*** Script:     |         var newDate = this.getParameter("sysparm_date");
*** Script:     |         newDate = newDate.split('-');
*** Script:     |         var newDate_day = newDate[2];
*** Script:     |         var newDate_month = newDate[1];
*** Script:     |         var newDate_year = newDate[0];
*** Script:     | 
*** Script:     |         var today = new Date();
*** Script:     |         var today_day = today.getDate();
*** Script:     |         var today_month = today.getMonth() + 1;
*** Script:     |         var today_year = today.getFullYear();
*** Script:     | 
*** Script:     |         var futureOneYearDate_year = today_year + 1;
*** Script:     | 
*** Script:     |         if (newDate_year > futureOneYearDate_year) {
*** Script:     |             //return true;
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year == futureOneYearDate_year && newDate_month > today_month) {
*** Script:     |             //return true;
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year == futureOneYearDate_year && newDate_month == today_month && newDate_day > today_day) {
*** Script:     |             //return true;
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year == today_year) {
*** Script:     |             if (newDate_month < today_month) {
*** Script:     |                 //return true;
*** Script:     |                 return 2;
*** Script:     |             } else if (newDate_month == today_month && newDate_day < today_day) {
*** Script:     |                 //return true;
*** Script:     |                 return 2;
*** Script:     |             }
*** Script:     |         } else if (newDate_year < today_year) {
*** Script:     |             //return true;
*** Script:     |             return 2;
*** Script:     |         } else {
*** Script:     |             return false;
*** Script:     |         }
*** Script:     | 
*** Script:     |     },
*** Script:     | 
*** Script:     |     validateDatesAfter1YearBefore5Years: function() {
*** Script:     |         var newDate = this.getParameter("sysparm_date");
*** Script:     |         newDate = newDate.split('-');
*** Script:     |         var newDate_day = newDate[2];
*** Script:     |         var newDate_month = newDate[1];
*** Script:     |         var newDate_year = newDate[0];
*** Script:     | 
*** Script:     |         var today = new Date();
*** Script:     |         var today_day = today.getDate();
*** Script:     |         var today_month = today.getMonth() + 1;
*** Script:     |         var today_year = today.getFullYear();
*** Script:     | 
*** Script:     |         var futureOneYearDate_year = today_year + 1;
*** Script:     |         var pastFiveYearsDate_year = today_year - 5;
*** Script:     | 
*** Script:     |         if (newDate_year > futureOneYearDate_year) {
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year == futureOneYearDate_year && newDate_month > today_month) {
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year == futureOneYearDate_year && newDate_month == today_month && newDate_day > today_day) {
*** Script:     |             return 1;
*** Script:     |         } else if (newDate_year < pastFiveYearsDate_year) {
*** Script:     |             return 2;
*** Script:     |         } else if (newDate_year == pastFiveYearsDate_year && newDate_month < today_month) {
*** Script:     |             return 2;
*** Script:     |         } else if (newDate_year == pastFiveYearsDate_year && newDate_month == today_month && newDate_day < today_day) {
*** Script:     |             return 2;
*** Script:     |         } else {
*** Script:     |             return false;
*** Script:     |         }
*** Script:     | 
*** Script:     |     },
*** Script:     | 
