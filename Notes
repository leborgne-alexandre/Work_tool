*** Script:     | 	getQueryrRoleDossier: function(selectedValues) {
*** Script:     | 
*** Script:     |         var exclusiveValues = [
*** Script:     |             "71b69fe3fb250b10209bf52102efdc56",
*** Script:     |             "00d65be3fb250b10209bf52102efdc90",
*** Script:     |             "d2c4a5ca3b428350731c898c24e45a4e"
*** Script:     |         ];
*** Script:     | 
*** Script:     |         var selectedArray = selectedValues ? selectedValues.split(',') : [];
*** Script:     | 
*** Script:     |         // Vérifie si un des 3 éléments exclusifs est sélectionné
*** Script:     |         var selectedExclusive = '';
*** Script:     | 
*** Script:     |         for (var i = 0; i < exclusiveValues.length; i++) {
*** Script:     |             if (selectedArray.indexOf(exclusiveValues[i]) > -1) {
*** Script:     |                 selectedExclusive = exclusiveValues[i];
*** Script:     |                 break;
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         var query = "question=535ec323fbe10b10209bf52102efdc30^inactive=false";
*** Script:     | 
*** Script:     |         // Si aucun des 3 n'est sélectionné
*** Script:     |         if (!selectedExclusive) {
*** Script:     |             query += "^ORDERBYorder";
*** Script:     |             return query;
*** Script:     |         }
*** Script:     | 
*** Script:     |         // Exclure les deux autres
*** Script:     |         var excluded = [];
*** Script:     |         for (var j = 0; j < exclusiveValues.length; j++) {
*** Script:     |             if (exclusiveValues[j] != selectedExclusive) {
*** Script:     |                 excluded.push(exclusiveValues[j]);
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         query += "^sys_idNOT IN" + excluded.join(',');
*** Script:     |         query += "^ORDERBYorder";
*** Script:     | 
*** Script:     |         return query;
*** Script:     |     },
*** Script:     | 
