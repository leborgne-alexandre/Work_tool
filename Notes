*** Script:     |     GetAccountClientType: function(getClientType, account) {
*** Script:     |         var clientType = ["association_patronale", "association_syndicale", "organisation"];
*** Script:     |         var accountType = ["ADCAPA", "ADCASY", "ZDCORG"];
*** Script:     |         var accountTypeDisplay = ["Employer's association", "Union association", "Organization"];
*** Script:     |         var accountTypeDisplayFq = ["Association Patronale", "Assocation Syndicale", "Organisation"];
*** Script:     |         var session = gs.getSession();
*** Script:     |         var language = session.getLanguage();
*** Script:     | 
*** Script:     |         getClientType = getClientType.toString();
*** Script:     |         for (var i = 0; i < accountType.length; i++) {
*** Script:     |             if (getClientType.contains(accountType[i])) {
*** Script:     |                 if (language == "fq") {
*** Script:     |                     this._addClientType(accountTypeDisplayFq[i], clientType[i]);
*** Script:     |                 } else {
*** Script:     |                     this._addClientType(accountTypeDisplay[i], clientType[i]);
*** Script:     |                 }
*** Script:     | 
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         var getEmployeeLocation = new GlideRecord('u_customer_location');
*** Script:     |         getEmployeeLocation.addQuery('account', account);
