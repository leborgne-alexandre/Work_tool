*** Script:     |     /**
*** Script:     |     	@name FilterSoldProductByTheme
*** Script:     |     	@author Unknown
*** Script:     |     	@second version author Nuno Martins
*** Script:     |     	@params account (sys_id of account selected in the form)
*** Script:     |     	@params theme (sys_id of consumer selected in the form)
*** Script:     |     	@description: Queries core utility table and returns the correct thematic list
*** Script:     |     	@date: 01/05/2025
*** Script:     |     	**/
*** Script:     |     FilterSoldProductByTheme: function(account, consumer) {
*** Script:     |         var catalogSysId = [];
*** Script:     |         var soldProducts = [];
*** Script:     |         var isAgent = false;
*** Script:     |         var clientType;
*** Script:     | 
*** Script:     |         //if loggin user is Agent or Admin
*** Script:     |         if ((gs.hasRole('sn_customerservice_agent') || gs.hasRole('admin') || gs.hasRole('sn_customerservice.svc_location_agent'))) {
*** Script:     |             isAgent = true;
*** Script:     |         }
*** Script:     | 
*** Script:     |         if (account != '') {
*** Script:     |             soldProducts = this._getValidSoldProductForAccountANDConsumer(account, consumer);
*** Script:     | 
*** Script:     |             clientType = account.u_account_type;
*** Script:     |             var catalogGrA = new GlideRecord('x_mdlcd_ccq_csm_me_x_mdlcd_ccq_csm_theme_topic_sp_relationship');
*** Script:     |             catalogGrA.addEncodedQuery('sold_productIN' + soldProducts + '^u_account_typeIN' + clientType + '^active=true');
*** Script:     |             if (isAgent === true) {
*** Script:     |                 catalogGrA.addEncodedQuery('^NQu_client_type=^u_account_type=^sold_product=');
*** Script:     |             } else {
*** Script:     |                 catalogGrA.addEncodedQuery('^NQu_account_typeIN' + clientType + '^sold_product=');
*** Script:     |             }
*** Script:     |             catalogGrA._skip_before_query_filter = true;
*** Script:     |             catalogGrA.query();
*** Script:     |             while (catalogGrA.next()) {
*** Script:     |                 catalogSysId.push(catalogGrA.u_thematique_ccq.toString());
*** Script:     |             }
*** Script:     |         } else if (consumer != '') {
*** Script:     |             soldProducts = this._getValidSoldProductForAccountANDConsumer(account, consumer);
*** Script:     | 
*** Script:     |             clientType = consumer.u_consumer_type;
*** Script:     |             var catalogGr = new GlideRecord('x_mdlcd_ccq_csm_me_x_mdlcd_ccq_csm_theme_topic_sp_relationship');
*** Script:     |             catalogGr.addEncodedQuery('sold_productIN' + soldProducts + '^u_client_typeIN' + clientType + '^active=true');
*** Script:     |             if (isAgent === true) {
*** Script:     |                 catalogGr.addEncodedQuery('^NQu_client_type=^u_account_type=^sold_product=');
*** Script:     |             } else {
*** Script:     |                 catalogGr.addEncodedQuery('^NQu_client_typeIN' + clientType + '^sold_product=');
*** Script:     |             }
*** Script:     |             catalogGr._skip_before_query_filter = true;
*** Script:     |             catalogGr.query();
*** Script:     |             while (catalogGr.next()) {
*** Script:     |                 catalogSysId.push(catalogGr.u_thematique_ccq.toString());
*** Script:     |             }
*** Script:     |         } else {
*** Script:     |             var catalogGrB = new GlideRecord('sc_catalog');
*** Script:     |             catalogGrB.addEncodedQuery('sys_scope=b68b7400db360150950460fdd396197e^titleNOT LIKEAutres^active=true^titleNOT LIKEautre^title!=Taches administratives^title!=Catalogue de service client'); // Query updated for the bug 187771
*** Script:     |             catalogGrB.query();
*** Script:     |             while (catalogGrB.next()) {
*** Script:     |                 catalogSysId.push(catalogGrB.getUniqueValue().toString())
*** Script:     |             }
*** Script:     |         }
*** Script:     |         return 'sys_idIN' + catalogSysId; // Returns the sys_id of the themes retrieved from the while loop + the hard-coded autres variable
*** Script:     |     },
*** Script:     | 
*** Script:     |     /**
*** Script:     |     	@name filterSujetByTheme
*** Script:     |     	@author Nuno Martins.
*** Script:     |     	@params theme (sys_id of thematic selected in the form)
*** Script:     |     	@params account (sys_id of account selected in the form)
*** Script:     |     	@params theme (sys_id of consumer selected in the form)
*** Script:     |     	@description: Queries core utility table and returns the correct sujet d'afair list
*** Script:     |     	@date: 01/05/2025
*** Script:     |     	**/
*** Script:     |     filterSujetByTheme: function(theme, account, consumer) {
*** Script:     |         var clientType;
*** Script:     |         var category = [];
*** Script:     | 
*** Script:     |         var isAgent = false;
*** Script:     | 
*** Script:     |         //if loggin user is Agent or Admin
*** Script:     |         if ((gs.hasRole('sn_customerservice_agent') || gs.hasRole('admin') || gs.hasRole('sn_customerservice.svc_location_agent'))) {
*** Script:     |             isAgent = true;
*** Script:     |         }
*** Script:     |         //if account is not empty, null or undifined 
*** Script:     |         if (account && account !== '') {
*** Script:     |             clientType = account.u_account_type;
*** Script:     |             //queries core utility table to return sujet daffaire options for the client type and thematic 
*** Script:     |             var sujet = new GlideRecord('x_mdlcd_ccq_csm_me_x_mdlcd_ccq_csm_theme_topic_sp_relationship');
*** Script:     |             sujet.addQuery('active', true);
*** Script:     |             sujet._skip_before_query_filter = true;
*** Script:     |             sujet.addEncodedQuery('u_account_typeIN' + clientType + '^u_thematique_ccqIN' + theme);
*** Script:     |             if (isAgent === true) {
*** Script:     |                 sujet.addEncodedQuery('^NQu_client_type=^u_account_type=^u_thematique_ccq=' + theme);
*** Script:     |             }
*** Script:     |             sujet.query();
*** Script:     |             while (sujet.next()) {
*** Script:     |                 category.push(sujet.getValue('u_sujet_daffaire_ccq'));
*** Script:     |             }
*** Script:     |         } else if (consumer && consumer !== '') {
*** Script:     |             //if consumer is not empty, null or undifined 
*** Script:     |             clientType = consumer.u_consumer_type;
*** Script:     |             //queries core utility table to return sujet daffaire options for the client type and thematic 
*** Script:     |             var sujet2 = new GlideRecord('x_mdlcd_ccq_csm_me_x_mdlcd_ccq_csm_theme_topic_sp_relationship');
*** Script:     |             sujet2._skip_before_query_filter = true;
*** Script:     |             sujet2.addQuery('active', true);
*** Script:     |             sujet2.addEncodedQuery('u_client_typeIN' + clientType + '^u_thematique_ccq=' + theme);
*** Script:     | 
*** Script:     |             if (isAgent === true) {
*** Script:     |                 sujet2.addEncodedQuery('^NQu_client_type=^u_account_type=^u_thematique_ccq=' + theme);
*** Script:     |             }
*** Script:     |             sujet2.query();
*** Script:     |             while (sujet2.next()) {
*** Script:     |                 category.push(sujet2.getValue('u_sujet_daffaire_ccq'));
*** Script:     |             }
*** Script:     | 
*** Script:     |         } else {
*** Script:     |             var categoryGr = new GlideRecord('sc_category');
*** Script:     |             categoryGr.addEncodedQuery('sys_scope=b68b7400db360150950460fdd396197e^parentISEMPTY^active=true^sc_catalog=' + theme + '^sc_catalogISNOTEMPTY');
*** Script:     |             categoryGr.query()
*** Script:     |             while (categoryGr.next()) {
*** Script:     |                 category.push(categoryGr.getUniqueValue());
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         var sujet = this.removeDuplicates(category); //removes duplicate sys_id from array
*** Script:     |         return 'sys_idIN' + sujet.toString(); //returns is one of filter with a string of sys_ids
*** Script:     |     },
