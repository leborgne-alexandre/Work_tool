*** Script:     |     /**
*** Script:     |     	@name _getValidSoldProductForAccountANDConsumer
*** Script:     |     	@author Nuno Martins.
*** Script:     |     	@clientcallable No. Create cliente facing function and call this function by passing params
*** Script:     |     	@params account (sys_id) 
*** Script:     |     	@params consumer (sys_id) 
*** Script:     |     	@description:receives a account and consumer record and validates the Sold Product Models given to the account type
*** Script:     |     	@date: 03/04/2025
*** Script:     |     	**/
*** Script:     |     _getValidSoldProductForAccountANDConsumer: function(account, consumer) {
*** Script:     |         var soldProduct = [];
*** Script:     | 
*** Script:     |         if (account != '') {
*** Script:     |             var accountType = account.u_account_type;
*** Script:     |             var validAccountSP = new GlideRecord('x_mdlcd_ccq_utilit_account_to_sold_product_rule');
*** Script:     |             validAccountSP.addEncodedQuery('u_account_typeIN' + accountType);
*** Script:     |             validAccountSP._skip_before_query_filter = true;
*** Script:     |             validAccountSP.query();
*** Script:     |             while (validAccountSP.next()) {
*** Script:     |                 soldProduct.push(validAccountSP.getValue('u_product_model'));
*** Script:     |             }
*** Script:     | 
