*** Script:     |     /* The following function mimics the getContactRoles property in this script include. But instead of the display
*** Script:     |      * value we want the value associeted with the responsibilty. Therefore we need a different code since the
*** Script:     |      * above fucntion might be used in other context.
*** Script:     |      * This is used for resolving the problem CSM-4119. 
*** Script:     |      */
*** Script:     |     getContactRolesValues: function() {
*** Script:     | 
*** Script:     |         // This fucntion is to search on an array of objects a value that we want.
*** Script:     |         function findIndexByProperty(array, searchValue, property) {
*** Script:     |             for (var i = 0; i < array.length; i++) {
*** Script:     |                 if (array[i][property] === searchValue) {
*** Script:     |                     return i;
*** Script:     |                 }
*** Script:     |             }
*** Script:     |             return -1; // Not found
*** Script:     |         }
*** Script:     | 
*** Script:     |         var array = [];
*** Script:     |         var contact = this.getParameter('sysparm_contactid');
*** Script:     |         var organization = this.getParameter('sysparm_organizationid');
*** Script:     | 
*** Script:     |         // Lets find the relationship the contact has. 
*** Script:     | 
*** Script:     |         var getContactRelationship = new GlideRecord('sn_customerservice_contact_relationship');
*** Script:     |         getContactRelationship.addQuery('contact', contact);
*** Script:     |         getContactRelationship.addQuery('company', organization);
*** Script:     |         getContactRelationship.addNotNullQuery("responsibility");
*** Script:     |         getContactRelationship.addEncodedQuery('u_start_date<=javascript:gs.endOfToday()^u_end_date>=javascript:gs.endOfToday()');
*** Script:     |         getContactRelationship.addQuery('u_active', true);
*** Script:     |         getContactRelationship.query();
*** Script:     | 
*** Script:     |         /* Second lets find the the sys_id and the value of the responsibilites that exist.
*** Script:     |          * This way we have enough information to compare instead of using the display values
*** Script:     |          * which when comparing string originates errors.
*** Script:     |          */
*** Script:     |         var getResponsibilityValues = new GlideRecord("sn_customerservice_responsibility_def");
*** Script:     |         getResponsibilityValues.addNotNullQuery("u_value");
*** Script:     |         getResponsibilityValues.query();
*** Script:     |         var responsibilites = [];
*** Script:     | 
*** Script:     |         while (getResponsibilityValues.next()) {
*** Script:     |             // Create an array of objects that store the sys_id and the value of the responsiblities
*** Script:     |             responsibilites.push({
*** Script:     |                 id: getResponsibilityValues.getValue('sys_id'),
*** Script:     |                 value: getResponsibilityValues.getValue('u_value')
*** Script:     |             });
*** Script:     |         }
*** Script:     | 
*** Script:     |         /* Now lets compare the sys_id we find to the sys_id that has the value f.1 - "Personne déléguée autorisée"
*** Script:     |          * If its not "Personne déléguée autorisée" store in an array the value of responsibility and not the sys_id.
*** Script:     |          */
*** Script:     | 
*** Script:     |         var sysidOfPersoneDelege = responsibilites[findIndexByProperty(responsibilites, 'f.1', "value")].id;
*** Script:     | 
*** Script:     |         while (getContactRelationship.next()) {
*** Script:     |             if (getContactRelationship.responsibility != sysidOfPersoneDelege) {
*** Script:     | 
*** Script:     |                 // Push to the array the value of the responsibility that the getContactRelationship.responsibility (a sys_id) has
*** Script:     |                 array.push(responsibilites[findIndexByProperty(responsibilites, String(getContactRelationship.responsibility), "id")].value);
*** Script:     |             }
*** Script:     |         }
*** Script:     | 
*** Script:     |         return (JSON.stringify(array));
*** Script:     |     },
*** Script:     | 
*** Script:     |     /* The following function serves to return the values of the responsibilites of the records that were passed
*** Script:     |      * This is used for resolving the enhancement CSM-4099.
*** Script:     |      * @parameters: sysparm_recordsid: An array of records; sysparm_nameofthetable: The name of the table; sysparm_nameofresponsibility:
*** Script:     |      * since this code is going to be used, possibly by sn_customerservice_contact_relationship and
*** Script:     |      * sn_customerservice_consumer_contact_relationship
*** Script:     |      * and they have different column names for responsibility we have to pass it in the parameters
*** Script:     |      * @returns: an arry of responsibility values.
*** Script:     |      */
*** Script:     |     getChoosenResponsibilites: function() {
*** Script:     |         // This fucntion is to search on an array of objects a value that we want.
*** Script:     |         function findIndexByProperty(array, searchValue, property) {
*** Script:     |             for (var i = 0; i < array.length; i++) {
*** Script:     |                 if (array[i][property] === searchValue) {
*** Script:     |                     return i;
*** Script:     |                 }
*** Script:     |             }
*** Script:     |             return -1; // Not found
*** Script:     |         }
*** Script:     | 
*** Script:     |         // Create an array of objects that store the sys_id and the value of the responsiblities on the system 
*** Script:     |         var getResponsibilityValues = new GlideRecord("sn_customerservice_responsibility_def");
*** Script:     |         getResponsibilityValues.addNotNullQuery("u_value");
*** Script:     |         getResponsibilityValues.query();
*** Script:     |         var responsibilites = [];
*** Script:     | 
*** Script:     |         while (getResponsibilityValues.next()) {
*** Script:     |             responsibilites.push({
*** Script:     |                 id: getResponsibilityValues.getValue('sys_id'),
*** Script:     |                 value: getResponsibilityValues.getValue('u_value')
*** Script:     |             });
*** Script:     |         }
*** Script:     | 
*** Script:     |         // Lets find the records information on the table specified
*** Script:     | 
*** Script:     |         var array = [];
*** Script:     |         var recordsIds = this.getParameter('sysparm_recordsid');
*** Script:     |         var nameOfTheTable = this.getParameter('sysparm_nameofthetable');
*** Script:     |         var nameOfResponsibility = this.getParameter('sysparm_nameofresponsibility');
*** Script:     | 
*** Script:     |         recordsIds = recordsIds.split(',');
*** Script:     | 
*** Script:     |         var getRecords = new GlideRecord(nameOfTheTable);
*** Script:     | 
*** Script:     |         for (var i = 0; i < recordsIds.length; i++) {
*** Script:     |             getRecords.get(recordsIds[i]);
*** Script:     |             getRecords.getValue(nameOfResponsibility);
*** Script:     | 
*** Script:     |             // Push to the array the value of the responsibility that the getRecords.getValue(nameOfResponsibility) (a sys_id) has
*** Script:     |             array.push(responsibilites[findIndexByProperty(responsibilites, String(getRecords.getValue(nameOfResponsibility)), "id")].value);
*** Script:     |         }
*** Script:     | 
*** Script:     |         // An array with values of the responsibilities that the records passed have
*** Script:     |         return (JSON.stringify(array));
*** Script:     |     },
