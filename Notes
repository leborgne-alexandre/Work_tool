*** Script:     |     var selectedDate = new Date(newValue + 'T00:00:00'); // Force local timezone
*** Script:     |     var today = new Date();
*** Script:     |     today.setHours(0, 0, 0, 0); // Strip time from today
*** Script:     | 
*** Script:     |     // Check if selected date is after today
*** Script:     |     if (selectedDate <= today) {
*** Script:     |         g_form.clearValue('date_de_fin');
*** Script:     | 		g_form.showFieldMsg('date_de_fin', getMessage("La date de fin doit être supérieure à la date du jour"), 'error');
*** Script:     |     }
*** Script:     | 
