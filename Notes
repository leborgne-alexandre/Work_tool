*** Script:     | 
*** Script:     |     returnExistingRelationshipsExcludingEntrepriseOnes: function() {
*** Script:     | 
*** Script:     |         var orgThatIsChanging = this.getParameter("sysparm_orgThatIsChanging");
*** Script:     |         var personThatIsSelected = this.getParameter("sysparm_personThatIsSelected");
*** Script:     | 
*** Script:     |         var rolesDetails = {};
*** Script:     | 
*** Script:     |         var gr = new GlideRecord("sn_customerservice_responsibility_def");
*** Script:     |         gr.addEncodedQuery("u_entreprise_role=false^type=customer_contact^name!=NULL");
*** Script:     |         gr.query();
*** Script:     | 
*** Script:     |         while (gr.next()) {
*** Script:     |             rolesDetails[gr.sys_id.toString()] = gr.name.toString();
*** Script:     |         }
*** Script:     | 
*** Script:     |         var relationships = [];
*** Script:     | 
*** Script:     |         var gr = new GlideRecord("sn_customerservice_contact_relationship");
*** Script:     |         // We don't care if it's the inverse or not, they will always be active both or they won't exist
*** Script:     |         gr.addEncodedQuery("company=" + orgThatIsChanging + "^contact=" + personThatIsSelected + "^responsibilityIN" + Object.keys(rolesDetails).toString());
*** Script:     |         gr.query();
*** Script:     | 
*** Script:     |         while (gr.next()) {
*** Script:     |             var responsibilitySysId = gr.responsibility.toString();
*** Script:     |             var relationshipName = rolesDetails[responsibilitySysId] || ""; // Grab the name from rolesDetails or return empty string if not found
*** Script:     | 
*** Script:     |             relationships.push({
*** Script:     |                 "name": relationshipName,
*** Script:     |                 "sys_id": responsibilitySysId,
*** Script:     |                 "endDate": new GlideDateTime(gr.u_end_date).getDate()
*** Script:     |             })
*** Script:     |         }
*** Script:     | 
*** Script:     |         return JSON.stringify(relationships);
*** Script:     |     },
